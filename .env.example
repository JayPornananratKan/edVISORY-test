# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres123
DB_DATABASE=expense_tracker
DB_SYNCHRONIZE=true
DB_LOGGING=false

# Server Configuration
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# Custom Session Configuration
CUSTOM_SESSION_SECRET=your-super-secret-session-key-change-this-in-production
SESSION_EXPIRY_HOURS=24

# Google Sheets Integration (Optional)
# GOOGLE_SHEETS_CREDENTIALS={"type":"service_account","project_id":"your-project-id",...}
# GOOGLE_SHEETS_SPREADSHEET_ID=your-spreadsheet-id-for-updates

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
