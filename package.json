{
  "name": "expense-tracker-backend",
  "version": "1.0.0",
  "description": "Backend API for expense tracking system",
  "main": "backend/dist/app.js",
  "scripts": {
    "build": "tsc -p backend/tsconfig.json",
    "start": "node backend/dist/app.js",
    "dev": "ts-node-dev --respawn --transpile-only backend/src/app.ts",
    "db:sync": "ts-node backend/src/scripts/sync.ts",
    "db:seed": "ts-node backend/src/scripts/seed.ts",
    "test": "jest",
    "lint": "eslint backend/src/**/*.ts",
    "lint:fix": "eslint backend/src/**/*.ts --fix"
  },
  "keywords": [
    "expense",
    "tracker",
    "backend",
    "api",
    "typescript"
  ],
  "author": "EdVISORY Test",
  "license": "MIT",
  "dependencies": {
    "@fastify/cors": "^8.5.0",
    "@fastify/helmet": "^11.1.1",
    "@fastify/multipart": "^8.0.0",
    "bcrypt": "^5.1.1",
    "csv-parser": "^3.0.0",
    "csv-writer": "^1.6.0",
    "dotenv": "^16.3.1",
    "exceljs": "^4.4.0",
    "fastify": "^4.29.1",
    "fastify-joi": "^1.0.2",
    "joi": "^17.11.0",
    "pg": "^8.11.3",
    "pino": "^8.16.2",
    "pino-pretty": "^10.2.3",
    "rate-limiter-flexible": "^4.0.1",
    "typeorm": "^0.3.17",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/jest": "^29.5.8",
    "@types/node": "^20.8.10",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^6.10.0",
    "@typescript-eslint/parser": "^6.10.0",
    "eslint": "^8.53.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.2.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
